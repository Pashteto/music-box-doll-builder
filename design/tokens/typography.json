{
  "$meta": {
    "name": "linden_tar — typography tokens",
    "description": "High-contrast literary serif display (Fraunces) paired with a clean grotesque body (Mulish). Chosen to echo the antique, elegant serif of Olga Grechanova's exhibition posters while keeping mobile UI text crisp and legible.",
    "version": "0.1.0"
  },

  "fontFamilies": {
    "display": {
      "name": "Fraunces",
      "stack": "'Fraunces', 'Cormorant Garamond', Georgia, 'Times New Roman', serif",
      "googleFonts": "https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&display=swap",
      "note": "Display / headings / hero. A high-contrast 'old-style' variable serif with optical sizing and a soft, slightly uncanny character. Use the 144 optical size at large sizes for dramatic thick/thin contrast. Italics for poetic captions.",
      "axes": { "opsz": "9..144", "wght": "300..600", "ital": "0,1" }
    },
    "body": {
      "name": "Mulish",
      "stack": "'Mulish', 'Helvetica Neue', Arial, sans-serif",
      "googleFonts": "https://fonts.googleapis.com/css2?family=Mulish:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap",
      "note": "Body / UI / labels. A clean, low-contrast humanist sans with a calm, neutral tone that recedes behind the serif. Deliberately NOT Inter — Mulish has a slightly warmer, narrower rhythm that suits dense mobile UI without shouting."
    },
    "mono": {
      "name": "IBM Plex Mono",
      "stack": "'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace",
      "googleFonts": "https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&display=swap",
      "note": "Numerals, counters, technical labels (export resolution, step counter, price). Optional."
    }
  },

  "fluidScale": {
    "$comment": "Mobile-first sizes in rem (root 16px). Display uses tight leading; body uses generous leading. clamp() values suggested for fluid scaling.",
    "display-2xl": { "size": "3.25rem", "clamp": "clamp(2.75rem, 9vw, 3.25rem)", "lineHeight": "1.02", "weight": 400, "tracking": "-0.02em", "family": "display", "use": "Landing hero title." },
    "display-xl": { "size": "2.5rem", "clamp": "clamp(2.1rem, 7vw, 2.5rem)", "lineHeight": "1.04", "weight": 400, "tracking": "-0.015em", "family": "display", "use": "Screen titles, paywall headline." },
    "display-lg": { "size": "1.875rem", "lineHeight": "1.08", "weight": 400, "tracking": "-0.01em", "family": "display", "use": "Section headings." },
    "display-md": { "size": "1.5rem", "lineHeight": "1.15", "weight": 500, "tracking": "-0.005em", "family": "display", "use": "Card titles, modal titles." },
    "serif-italic": { "size": "1.125rem", "lineHeight": "1.4", "weight": 400, "italic": true, "family": "display", "use": "Poetic captions, epigraphs (e.g. 'a goodnight kiss...')." },
    "body-lg": { "size": "1.0625rem", "lineHeight": "1.6", "weight": 400, "tracking": "0", "family": "body", "use": "Lead paragraph." },
    "body-md": { "size": "0.9375rem", "lineHeight": "1.6", "weight": 400, "tracking": "0", "family": "body", "use": "Default body / UI text." },
    "body-sm": { "size": "0.8125rem", "lineHeight": "1.5", "weight": 400, "tracking": "0.01em", "family": "body", "use": "Captions, helper text." },
    "label": { "size": "0.75rem", "lineHeight": "1.3", "weight": 600, "tracking": "0.16em", "family": "body", "transform": "uppercase", "use": "Eyebrow labels, slot names, step labels." },
    "label-sm": { "size": "0.6875rem", "lineHeight": "1.3", "weight": 600, "tracking": "0.18em", "family": "body", "transform": "uppercase", "use": "Tiny tags, badges." },
    "mono-sm": { "size": "0.75rem", "lineHeight": "1.3", "weight": 500, "tracking": "0.02em", "family": "mono", "use": "Counters, price, resolution." }
  },

  "weights": {
    "light": 300,
    "regular": 400,
    "medium": 500,
    "semibold": 600,
    "bold": 700
  },

  "tracking": {
    "tighter": "-0.02em",
    "tight": "-0.01em",
    "normal": "0",
    "wide": "0.08em",
    "wider": "0.16em",
    "widest": "0.2em"
  },

  "leading": {
    "none": "1",
    "display": "1.04",
    "snug": "1.15",
    "normal": "1.45",
    "relaxed": "1.6"
  }
}
