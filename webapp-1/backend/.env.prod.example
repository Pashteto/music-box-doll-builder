# Production env for docker-compose.prod.yml. Copy to `.env` on the server and
# fill in a STRONG generated DB password. NEVER commit the real .env.
#   cp .env.prod.example .env && chmod 600 .env
# (.env and *.env are gitignored/dockerignored.)
DB_USER=dollbuilder
DB_NAME=dollbuilder
DB_PASSWORD=__CHANGE_ME__   # generate: openssl rand -base64 32
